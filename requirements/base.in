# urllib3 is the HTTP transport under requests (and therefore botocore, docker
# and selenium in the dev tree). The floor addresses CVE-2026-21441 (decompression
# bomb bypass on redirects, fixed in 2.6.3); the <3.0.0 cap avoids the next major.
# The pin was restored/re-affirmed via auto-remediation (#2, #11, #12) and verified
# consistent for #22: uv resolves this range to urllib3==2.7.0 in both
# requirements/base.txt and requirements/development.txt, with no conflicting or
# regressed pin elsewhere in the tree.
urllib3>=2.6.3,<3.0.0
# Security: CVE-2026-27199 - Windows device name handling in safe_join
werkzeug>=3.1.6,<4.0.0
# Security: CVE-2025-68146 - TOCTOU symlink vulnerability
filelock>=3.20.3,<4.0.0
# Security: decompression bomb fix (required by aiohttp 3.13.3)
brotli>=1.2.0,<2.0.0
numexpr>=2.9.0
# numpy 2.x upgrade (#17): the previous 1.26.4 pin predated the ecosystem
# migration to numpy 2. The resolved tree installs numpy 2.x with a
# compatible pandas (>=2.2.2 is the first pandas release supporting numpy 2);
# pyarrow>=24, numexpr>=2.10 and bottleneck>=1.4 all support numpy 2 as well.
# The abstract floor/cap lives in pyproject.toml ("numpy>=2.0.0, <2.3"); this
# note records the review outcome so the bump is intentional and auditable.
# pandas/numpy "current stable" review (#9): numpy 2.3 and pandas 3.0 both
# dropped Python 3.10, which this project still supports (requires-python
# >=3.10). numpy 2.2.6 and pandas 2.3.3 are the newest releases of the last
# 3.10-compatible series, and uv resolves the ranges above to exactly those
# versions in base.txt/development.txt, so the pins already track the current
# stable releases for the supported Python range.
numpy>=2.0.0,<2.3
# Security: CVE-2026-34073 (MEDIUM) - Improper Certificate Validation
cryptography>=49.0.0,<50.0.0
# Security: Snyk - XSS vulnerability in Mako templates
mako>=1.3.11,<2.0.0
# Security: CVE-2024-52338 (CRITICAL) - Deserialization of untrusted data in IPC/Parquet readers
pyarrow>=24.0.0,<25.0.0
# Security: CVE-2026-27459 - pyopenssl certificate validation
pyopenssl>=26.0.0,<27.0.0
# Security: CVE-2026-25645 (MEDIUM) - Insecure Temporary File
requests>=2.33.0,<3.0.0

# 5.0.0 has a sensitive deprecation used in other libs
# -> https://github.com/aio-libs/async-timeout/blob/master/CHANGES.rst#500-2024-10-31
async_timeout>=4.0.0,<5.0.0

# Known issue with 6.7.0 breaking a unit test, probably easy to fix, but will require
# a bit of attention to bump.
apispec>=6.0.0,<6.7.0

# 1.4.1 introduced a memory regression that exhausts memory in the test suite
# (https://github.com/marshmallow-code/marshmallow-sqlalchemy/issues/665). 1.4.2
# claimed a fix but did not address the root cause; only 1.5.0 actually fixes it.
marshmallow-sqlalchemy>=1.5.0

# needed for python 3.12 support
openapi-schema-validator>=0.6.3

# Pin setuptools <81 until all dependencies migrate from pkg_resources to importlib.metadata
# pkg_resources is deprecated and will be removed in setuptools 81+ (around 2025-11-30)
# Known affected packages: Preset's 'clients' package
# See docs/docs/contributing/pkg-resources-migration.md for details
setuptools<81

# google-auth 2.53+ dropped its transitive dependency on cachetools, which is
# imported directly by superset.db_engine_specs.aws_iam. We declare cachetools
# explicitly in pyproject.toml and pin google-auth to the post-drop range so
# the install path is internally consistent (#40962).
google-auth>=2.53.0,<3.0.0

# pyxlsb is pulled in transitively via pandas[excel] to parse the binary .xlsb
# format. 1.0.10 is the latest release on PyPI (published 2022-10-14) and has no
# published security advisories, so the pin is held at that version. It is
# LGPLv3+ licensed and tracked for eventual removal (see pyproject.toml
# [tool.liccheck.authorized_packages]); Superset's own upload flow only accepts
# xlsx/xls (EXCEL_EXTENSIONS), so no first-party code depends on it. Pinned here
# to make the reviewed version explicit (#21).
pyxlsb==1.0.10

# parsedatetime backs the human-readable relative-date parsing in
# superset.utils.date_parser (parse_human_datetime / DateRangeMigration). 2.6 is
# the latest release on PyPI (published 2020-05-31); versions only go up to 2.6,
# so there is nothing newer to bump to. It is Apache-2.0 licensed (an authorized
# license) and carries no published security advisories. Pinned here to make the
# reviewed version explicit (#20).
parsedatetime==2.6

# flask-wtf provides Superset's CSRF protection and form handling: FlaskForm
# (superset.views.base), CSRFProtect (superset.extensions), generate_csrf
# (superset.security.api) and the CSRFError / same_origin helpers. It is also a
# transitive dependency of flask-appbuilder. 1.3.0 is the latest release on PyPI
# (published 2026-04-23); there is nothing newer to bump to. It is BSD-3-Clause
# licensed (an authorized license) and carries no published security advisories.
# Pinned here to make the reviewed version explicit (#18).
flask-wtf==1.3.0

# odfpy is pulled in transitively via pandas[excel] to read/write the
# OpenDocument spreadsheet (.ods) format. 1.4.1 is the latest release on PyPI
# (published 2020-01-18); there is nothing newer to bump to. It is Apache
# Software licensed (an authorized license) and carries no published security
# advisories. Superset's own upload flow only accepts xlsx/xls, so no
# first-party code depends on it. Pinned here to make the reviewed version
# explicit (#19).
odfpy==1.4.1

# flask-sqlalchemy backs Flask-AppBuilder's and Flask-Migrate's ORM
# integration (the shared db session/model registry). The lock previously
# pinned the end-of-life 2.5.1 release; the 3.0.x line is the current
# supported series and is fully compatible with the sqlalchemy 1.4 tree
# Superset targets (flask-sqlalchemy 3.0.x requires SQLAlchemy>=1.4.18).
# The <3.1 cap is deliberate: flask-sqlalchemy 3.1+ requires SQLAlchemy>=2.0,
# which conflicts with Superset's "sqlalchemy>=1.4, <2" pin in pyproject.toml.
# uv resolves this range to flask-sqlalchemy==3.0.5 (#14).
flask-sqlalchemy>=3.0.3,<3.1
